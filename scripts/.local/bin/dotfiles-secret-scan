#!/usr/bin/env bash
set -euo pipefail

repo="${1:-$HOME/.dotfiles}"

if [[ ! -d "$repo" ]]; then
  printf 'Repo not found: %s\n' "$repo" >&2
  exit 2
fi

patterns=(
  'AKIA[0-9A-Z]{16}'
  '-----BEGIN (RSA|DSA|EC|OPENSSH|PGP) PRIVATE KEY-----'
  'ghp_[A-Za-z0-9_]{30,}'
  'github_pat_[A-Za-z0-9_]{30,}'
  'xox[baprs]-[A-Za-z0-9-]{10,}'
  '(api[_-]?key|secret|token|password|passwd|pwd)[[:space:]]*[:=][[:space:]]*["'\'']?[^"'\''[:space:]]{8,}'
)

tmp="$(mktemp)"
trap 'rm -f "$tmp"' EXIT

cd "$repo"

for pattern in "${patterns[@]}"; do
  rg -n -I --hidden \
    --glob '!.git/**' \
    --glob '!backup/**' \
    --glob '!*.env.example' \
    --glob '!install.log' \
    --glob '!*.png' \
    --glob '!*.pf2' \
    -e "$pattern" . >>"$tmp" || true
done

if [[ -s "$tmp" ]]; then
  printf 'Potential secrets found. Review before pushing:\n\n'
  sed -E 's/(=|:)[[:space:]]*[^[:space:]]+/\1 [REDACTED]/g' "$tmp" | sort -u
  exit 1
fi

printf 'No obvious secrets found in %s\n' "$repo"
