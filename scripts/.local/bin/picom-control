#!/usr/bin/env bash
set -euo pipefail

command_name="${1:-restart}"
config="${PICOM_CONFIG:-$HOME/.config/picom/picom.conf}"
state_dir="${XDG_STATE_HOME:-$HOME/.local/state}/picom"
runtime_dir="${XDG_RUNTIME_DIR:-/tmp}"
pid_file="$state_dir/picom.pid"
log_file="$state_dir/picom.log"
lock_dir="$runtime_dir/picom-control.lock"

usage() {
  cat <<'EOF'
Usage: picom-control [start|stop|restart|status]

Manage picom safely for i3 reloads/restarts.
EOF
}

acquire_lock() {
  local attempts=0
  if [[ ! -d "$runtime_dir" || ! -w "$runtime_dir" ]]; then
    lock_dir="${TMPDIR:-/tmp}/picom-control-${UID:-$(id -u)}.lock"
  fi

  while ! mkdir "$lock_dir" 2>/dev/null; do
    attempts=$((attempts + 1))
    if ((attempts >= 40)); then
      printf 'picom-control: could not acquire lock: %s\n' "$lock_dir" >&2
      exit 1
    fi
    sleep 0.05
  done
  trap 'rmdir "$lock_dir" 2>/dev/null || true' EXIT
}

is_running() {
  pgrep -x picom >/dev/null 2>&1
}

wait_until_stopped() {
  local attempts=0
  while is_running; do
    attempts=$((attempts + 1))
    if ((attempts >= 40)); then
      return 1
    fi
    sleep 0.05
  done
}

stop_picom() {
  if ! is_running; then
    return 0
  fi

  pkill -TERM -x picom 2>/dev/null || true
  if ! wait_until_stopped; then
    pkill -KILL -x picom 2>/dev/null || true
    wait_until_stopped || true
  fi
}

start_picom() {
  mkdir -p "$state_dir"

  if [[ -z "${DISPLAY:-}" ]]; then
    printf 'picom-control: DISPLAY is not set; refusing to start picom.\n' >&2
    exit 1
  fi

  if [[ ! -f "$config" ]]; then
    printf 'picom-control: missing config: %s\n' "$config" >&2
    exit 1
  fi

  if is_running; then
    return 0
  fi

  picom \
    --daemon \
    --config "$config" \
    --write-pid-path "$pid_file" \
    --log-level warn \
    --log-file "$log_file"

  sleep 0.15
  if ! is_running; then
    printf 'picom-control: picom failed to start; check %s\n' "$log_file" >&2
    exit 1
  fi
}

case "$command_name" in
  start)
    acquire_lock
    start_picom
    ;;
  stop)
    acquire_lock
    stop_picom
    ;;
  restart)
    acquire_lock
    stop_picom
    start_picom
    ;;
  status)
    if is_running; then
      printf 'picom running'
      if [[ -f "$pid_file" ]]; then
        printf ' (pid %s)' "$(sed -n '1p' "$pid_file" 2>/dev/null || true)"
      fi
      printf '\n'
    else
      printf 'picom not running\n'
      exit 1
    fi
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    printf 'Unknown command: %s\n\n' "$command_name" >&2
    usage >&2
    exit 2
    ;;
esac
