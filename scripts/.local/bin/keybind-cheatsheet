#!/usr/bin/env bash
set -euo pipefail

cat <<'EOF' | rofi -dmenu \
  -i \
  -p "Atalhos" \
  -mesg "Digite para filtrar. Enter fecha a lista." \
  -theme-str 'window { width: 64%; border: 2px; border-color: #3c3836; background-color: #fbf1c7; }' \
  -theme-str 'mainbox { padding: 18px; spacing: 10px; }' \
  -theme-str 'inputbar { padding: 10px; border: 1px; border-color: #7c6f64; background-color: #ebdbb2; }' \
  -theme-str 'prompt { text-color: #1d2021; font: "JetBrainsMono Nerd Font Bold 11"; }' \
  -theme-str 'entry { text-color: #1d2021; font: "JetBrainsMono Nerd Font 10"; }' \
  -theme-str 'message { padding: 6px; text-color: #3c3836; }' \
  -theme-str 'listview { lines: 22; columns: 1; spacing: 4px; }' \
  -theme-str 'element { padding: 7px 10px; border-radius: 6px; }' \
  -theme-str 'element selected { background-color: #d5c4a1; text-color: #1d2021; }' \
  -theme-str 'element-text { font: "JetBrainsMono Nerd Font 10"; text-color: #1d2021; }' >/dev/null
󰘳  GERAL
  Super + Enter             Terminal
  Super + D                 Launcher de apps
  Super + Shift + F         Explorador de arquivos
  Super + Tab               Trocar janela pelo rofi
  Super + /                 Este cheat sheet
  Super + Shift + E         Menu de energia
  Super + Shift + W         Trocar wallpaper
  Super + Shift + Q         Fechar janela
  Super + Ctrl + R          Reiniciar i3

󰖲  JANELAS
  Super + H/J/K/L           Focar esquerda/baixo/cima/direita
  Super + Setas             Focar por direcao
  Super + Shift + H/J/K/L   Mover janela
  Super + Shift + Setas     Mover janela
  Super + F                 Fullscreen
  Super + V                 Split vertical
  Super + B                 Split horizontal
  Super + S                 Layout stacking
  Super + W                 Layout tabbed
  Super + E                 Alternar split
  Super + Space             Alternar foco tiling/floating
  Super + Shift + Space     Alternar floating
  Super + P                 Mover workspace para outro monitor

󰃖  WORKSPACES
  Super + 1..0              Ir para workspace 1..10
  Super + Shift + 1..0      Mover janela para workspace 1..10

󰆍  SCRATCHPAD E BLOQUEIO
  Super + Shift + -         Enviar janela para scratchpad
  Super + -                 Mostrar scratchpad
  Super + Escape            Bloquear tela

󰩨  RESIZE
  Super + R                 Entrar no modo resize
  H/J/K/L                   Redimensionar no modo resize
  Setas                     Redimensionar no modo resize
  Enter / Escape            Sair do modo resize

󰄀  MIDIA E SISTEMA
  Print                     Screenshot area
  Shift + Print             Screenshot tela inteira para clipboard
  Super + Print             Screenshot tela inteira em Pictures/Screenshots
  Super + Shift + S         Screenshot area
  Super + Shift + R         Gravar tela ou area
  Volume +/-                Ajustar volume
  Mute                      Mutar audio
  Mic Mute                  Mutar microfone
  Brilho +/-                Ajustar brilho
  Play / Next / Prev        Controle de midia
  Display                   Abrir arandr
EOF
