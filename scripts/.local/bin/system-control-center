#!/usr/bin/env bash
set -euo pipefail

style='window {width: 420px; border: 2px; border-color: #fbf1c7; border-radius: 8px; background-color: #1d2021f2;} listview {lines: 14;} element {padding: 9px 12px;} element selected {background-color: #3c3836; text-color: #fbf1c7;} entry {placeholder: "System";}'

run_terminal() {
  local title="$1"
  local command="$2"

  env TERMINAL_TITLE="$title" TERMINAL_COMMAND="$command" alacritty --title "$title" -e bash -lc '
    export PATH="$HOME/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
    clear
    printf "\033[1;33m%s\033[0m\n\n" "$TERMINAL_TITLE"
    eval "$TERMINAL_COMMAND"
    status=$?
    printf "\n\033[2mStatus: %s\033[0m\n" "$status"
    printf "Pressione Enter para fechar..."
    read -r _
    exit "$status"
  '
}

choices=$(
  cat <<'EOF'
Wallpaper
Power Menu
Energy Profile
Dev Services
Monitor Profiles
Audio Output
Bluetooth
Wi-Fi
Notifications
Screenshot Area
Screen Recording
File Manager
Presentation Mode
System Health
Boot Analysis
System Maintenance
Apply Gruvbox Theme
Backup Dotfiles
Secret Scan
Security Baseline
Edit Dotfiles
Reload i3
Restart Polybar
EOF
)

choice="$(printf '%s\n' "$choices" | rofi -dmenu -p "Control Center" -theme-str "$style")"

case "$choice" in
  Wallpaper) wallpaper-picker ;;
  "Power Menu") "$HOME/.config/rofi/power-menu.sh" ;;
  "Energy Profile") power-profile-indicator menu ;;
  "Dev Services") dev-services-manager ;;
  "Monitor Profiles") monitor-manager menu ;;
  "Audio Output") audio-switcher ;;
  Bluetooth) blueman-manager ;;
  Wi-Fi) nm-connection-editor ;;
  Notifications) dunst-notifications menu ;;
  "Screenshot Area") flameshot gui ;;
  "Screen Recording") screen-recorder menu ;;
  "File Manager") tui-file-manager ;;
  "Presentation Mode") presentation-mode toggle ;;
  "System Health") run_terminal "SYSTEM HEALTH" 'system-health' ;;
  "Boot Analysis") run_terminal "BOOT ANALYSIS" 'boot-analysis' ;;
  "System Maintenance") run_terminal "SYSTEM MAINTENANCE" 'system-maintenance all' ;;
  "Apply Gruvbox Theme") apply-theme gruvbox ;;
  "Backup Dotfiles") run_terminal "BACKUP DOTFILES" 'backup-dotfiles' ;;
  "Secret Scan") run_terminal "SECRET SCAN" 'dotfiles-secret-scan' ;;
  "Security Baseline") run_terminal "SECURITY BASELINE" 'security-baseline' ;;
  "Edit Dotfiles") alacritty --title "DOTFILES" -e nvim "$HOME/.dotfiles" ;;
  "Reload i3") i3-msg reload ;;
  "Restart Polybar") "$HOME/.config/polybar/launch.sh" ;;
  ""|*) exit 0 ;;
esac
