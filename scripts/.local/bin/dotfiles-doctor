#!/usr/bin/env bash
set -uo pipefail

dotfiles="${DOTFILES_DIR:-$HOME/.dotfiles}"
profile="${DOTFILES_PROFILE:-thinkpad-e14-amd}"
profile_name="portable"
profile_description="Portable dotfiles defaults"
ok=0
warn=0
fail=0

green=$'\033[32m'
yellow=$'\033[33m'
red=$'\033[31m'
reset=$'\033[0m'

print_status() {
  local level="$1"
  local label="$2"
  local detail="${3:-}"

  case "$level" in
    ok)
      ok=$((ok + 1))
      printf "%sOK%s    %-28s %s\n" "$green" "$reset" "$label" "$detail"
      ;;
    warn)
      warn=$((warn + 1))
      printf "%sWARN%s  %-28s %s\n" "$yellow" "$reset" "$label" "$detail"
      ;;
    fail)
      fail=$((fail + 1))
      printf "%sFAIL%s  %-28s %s\n" "$red" "$reset" "$label" "$detail"
      ;;
  esac
}

check_command() {
  local cmd="$1"
  if command -v "$cmd" >/dev/null 2>&1; then
    print_status ok "$cmd" "$(command -v "$cmd")"
  else
    print_status fail "$cmd" "missing"
  fi
}

check_service() {
  local unit="$1"
  local active enabled
  active="$(systemctl is-active "$unit" 2>/dev/null || true)"
  enabled="$(systemctl is-enabled "$unit" 2>/dev/null || true)"

  if [[ "$active" == "active" ]]; then
    print_status ok "$unit" "$active / $enabled"
  elif [[ "$active" == "unknown" && "$enabled" == "not-found" ]]; then
    print_status warn "$unit" "not installed"
  else
    print_status warn "$unit" "${active:-unknown} / ${enabled:-unknown}"
  fi
}

check_user_service() {
  local unit="$1"
  local active
  active="$(systemctl --user is-active "$unit" 2>/dev/null || true)"
  if [[ "$active" == "active" ]]; then
    print_status ok "user:$unit" "$active"
  else
    print_status warn "user:$unit" "${active:-missing}"
  fi
}

check_symlink() {
  local path="$1"
  if [[ -L "$path" ]]; then
    print_status ok "$path" "-> $(readlink "$path")"
  elif [[ -e "$path" ]]; then
    print_status warn "$path" "exists but is not a symlink"
  else
    print_status fail "$path" "missing"
  fi
}

load_profile() {
  local profile_file="$dotfiles/profiles/$profile.conf"
  local local_profile_file="$dotfiles/profiles/$profile.local.conf"

  if [[ -f "$profile_file" ]]; then
    # shellcheck disable=SC1090
    source "$profile_file"
    profile_name="${DOTFILES_PROFILE_NAME:-$profile}"
    profile_description="${DOTFILES_PROFILE_DESCRIPTION:-}"
  fi

  if [[ -f "$local_profile_file" ]]; then
    # shellcheck disable=SC1090
    source "$local_profile_file"
    profile_name="${DOTFILES_PROFILE_NAME:-$profile_name}"
    profile_description="${DOTFILES_PROFILE_DESCRIPTION:-$profile_description}"
  fi
}

load_profile

printf "DOTFILES DOCTOR\n"
printf "Repo: %s\n\n" "$dotfiles"
printf "== Profile ==\n"
if [[ -f "$dotfiles/profiles/$profile.conf" ]]; then
  print_status ok "profile" "$profile_name"
else
  print_status warn "profile" "$profile not found; portable defaults"
fi
if [[ -n "$profile_description" ]]; then
  print_status ok "profile details" "$profile_description"
fi

printf "== Commands ==\n"
for cmd in dotfiles i3 polybar rofi rofi-drun picom picom-control pavucontrol audio-volume dunst alacritty tmux nvim yazi feh flameshot autorandr xrandr xinput xset pactl sensors dock-health security-check performance-health system-mode dev-stack-manager dev-db backup-real backup-health browser-state dotfiles-inventory dotfiles-check snapshot-manager i3lock-blur idle-lock-daemon; do
  check_command "$cmd"
done

printf "\n== Development Commands ==\n"
for cmd in node npm pnpm yarn python pip pipx pyenv mise rustc cargo rust-analyzer go java javac mvn gradle dotnet mono cmake ninja bear clang clang++ lldb gdb valgrind lazygit zoxide atuin direnv shellcheck shfmt stylua prettier eslint black ruff mypy lua-language-server typescript-language-server bash-language-server yaml-language-server taplo docker docker-compose podman psql mariadb adb fastboot flutter ollama code gh kubectl helm terraform aws az gcloud; do
  check_command "$cmd"
done

if [[ -s /usr/share/nvm/init-nvm.sh ]]; then
  # nvm is a shell function on Arch, not a standalone executable.
  # shellcheck disable=SC1091
  source /usr/share/nvm/init-nvm.sh
  if type nvm >/dev/null 2>&1; then
    print_status ok "nvm" "shell function"
  else
    print_status fail "nvm" "not loaded"
  fi
else
  print_status fail "nvm" "init script missing"
fi

printf "\n== Symlinks ==\n"
for path in \
  "$HOME/.config/i3/config" \
  "$HOME/.config/polybar" \
  "$HOME/.config/rofi" \
  "$HOME/.config/nvim" \
  "$HOME/.config/tmux" \
  "$HOME/.config/yazi" \
  "$HOME/.local/bin/system-control-center" \
  "$HOME/.local/bin/tui-file-manager" \
  "$HOME/.local/bin/dock-health" \
  "$HOME/.local/bin/system-mode"; do
  check_symlink "$path"
done

printf "\n== Services ==\n"
for unit in NetworkManager.service bluetooth.service tlp.service lm_sensors.service thinkfan.service displaylink.service; do
  check_service "$unit"
done

printf "\n== Dev Services ==\n"
for unit in postgresql.service mariadb.service mongodb.service ollama.service; do
  active="$(systemctl is-active "$unit" 2>/dev/null || true)"
  enabled="$(systemctl is-enabled "$unit" 2>/dev/null || true)"
  if [[ "$enabled" == "disabled" || "$enabled" == "static" ]]; then
    print_status ok "$unit" "${active:-unknown} / on-demand"
  else
    print_status warn "$unit" "${active:-unknown} / $enabled"
  fi
done

fstrim_enabled="$(systemctl is-enabled fstrim.timer 2>/dev/null || true)"
fstrim_active="$(systemctl is-active fstrim.timer 2>/dev/null || true)"
if [[ "$fstrim_enabled" == "enabled" && "$fstrim_active" == "active" ]]; then
  print_status ok "fstrim.timer" "$fstrim_active / $fstrim_enabled"
else
  print_status warn "fstrim.timer" "${fstrim_active:-unknown} / ${fstrim_enabled:-unknown}"
fi

nm_wait_enabled="$(systemctl is-enabled NetworkManager-wait-online.service 2>/dev/null || true)"
if [[ "$nm_wait_enabled" == "disabled" ]]; then
  print_status ok "NM wait online" "disabled"
else
  print_status warn "NM wait online" "${nm_wait_enabled:-unknown}"
fi

printf "\n== User Services ==\n"
for unit in pipewire.service pipewire-pulse.service wireplumber.service xdg-desktop-portal.service xsettingsd.service dotfiles-maintenance.timer; do
  check_user_service "$unit"
done

printf "\n== Desktop Processes ==\n"
for proc in polybar dunst picom xss-lock xidlehook; do
  if pgrep -x "$proc" >/dev/null 2>&1; then
    print_status ok "$proc" "running"
  else
    print_status warn "$proc" "not running"
  fi
done

printf "\n== Display ==\n"
if [[ -n "${DISPLAY:-}" ]] && command -v xrandr >/dev/null 2>&1; then
  connected="$(xrandr --query 2>/dev/null | awk '/ connected/ {print $1}' | paste -sd ' ' -)"
  if [[ -n "$connected" ]]; then
    print_status ok "monitors" "$connected"
  else
    print_status warn "monitors" "none detected"
  fi
else
  print_status warn "DISPLAY" "not available"
fi

if lsmod 2>/dev/null | awk '{print $1}' | grep -qx evdi; then
  print_status ok "evdi module" "loaded"
else
  print_status warn "evdi module" "not loaded"
fi

if command -v autorandr >/dev/null 2>&1; then
  current_profile="$(autorandr --current 2>/dev/null | paste -sd ' ' -)"
  if [[ -n "$current_profile" ]]; then
    print_status ok "autorandr" "$current_profile"
  else
    print_status warn "autorandr" "no current profile"
  fi
fi

printf "\n== Power And Sensors ==\n"
if [[ -d /sys/class/power_supply/BAT0 ]]; then
  cap="$(cat /sys/class/power_supply/BAT0/capacity 2>/dev/null || printf '?')"
  status="$(cat /sys/class/power_supply/BAT0/status 2>/dev/null || printf '?')"
  print_status ok "battery" "$cap% / $status"
else
  print_status warn "battery" "BAT0 missing"
fi

if command -v sensors >/dev/null 2>&1; then
  cpu_temp="$(sensors 2>/dev/null | awk '/Tctl|Package id 0|CPU/ {print $2; exit}')"
  print_status ok "sensors" "${cpu_temp:-available}"
else
  print_status warn "sensors" "command missing"
fi

printf "\n== Maintenance ==\n"
cache_size="$(du -sh "$HOME/.cache" 2>/dev/null | awk '{print $1}')"
print_status ok "user cache" "${cache_size:-unknown}"

orphan_count="$(pacman -Qtdq 2>/dev/null | wc -l | tr -d ' ')"
if [[ "${orphan_count:-0}" -gt 0 ]]; then
  print_status warn "orphan packages" "$orphan_count"
else
  print_status ok "orphan packages" "0"
fi

if command -v yay >/dev/null 2>&1; then
  aur_updates="$(yay -Qua 2>/dev/null | wc -l | tr -d ' ')"
  if [[ "${aur_updates:-0}" -gt 0 ]]; then
    print_status warn "AUR updates" "$aur_updates"
  else
    print_status ok "AUR updates" "0"
  fi
else
  print_status warn "yay" "not installed"
fi

if [[ -f "$dotfiles/backup/last-backup.txt" ]]; then
  backup_line="$(sed -n '1p' "$dotfiles/backup/last-backup.txt" 2>/dev/null)"
  print_status ok "last backup" "${backup_line:-available}"
else
  print_status warn "last backup" "missing"
fi

printf "\n== GRUB ==\n"
if [[ -f /usr/share/grub/themes/lenovo-thinkpad-efi/theme.txt ]]; then
  print_status ok "GRUB theme" "lenovo-thinkpad-efi"
else
  print_status warn "GRUB theme" "not installed"
fi

printf "\n== Git ==\n"
if [[ -d "$dotfiles/.git" ]]; then
  if git -C "$dotfiles" diff --quiet && git -C "$dotfiles" diff --cached --quiet; then
    print_status ok "dotfiles git" "clean"
  else
    print_status warn "dotfiles git" "dirty"
  fi
  remote="$(git -C "$dotfiles" remote get-url origin 2>/dev/null || true)"
  if [[ -n "$remote" ]]; then
    print_status ok "origin" "$remote"
  else
    print_status warn "origin" "not configured"
  fi
  upstream="$(git -C "$dotfiles" rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
  if [[ -n "$upstream" ]]; then
    ahead="$(git -C "$dotfiles" rev-list --count "$upstream"..HEAD 2>/dev/null || printf 0)"
    if [[ "$ahead" == "0" ]]; then
      print_status ok "unpushed commits" "0"
    else
      print_status warn "unpushed commits" "$ahead"
    fi
  else
    print_status warn "upstream" "not configured"
  fi
else
  print_status fail "dotfiles git" "not a repo"
fi

printf "\nSummary: %s OK, %s WARN, %s FAIL\n" "$ok" "$warn" "$fail"
((fail == 0))
