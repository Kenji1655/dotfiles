#!/usr/bin/env bash
set -euo pipefail

export DISPLAY="${DISPLAY:-:0}"
export XAUTHORITY="${XAUTHORITY:-$HOME/.Xauthority}"

style='window {width: 500px; border: 2px; border-color: #fbf1c7; border-radius: 8px; background-color: #1d2021f2;} listview {lines: 10;} element {padding: 9px 12px;} element selected {background-color: #3c3836; text-color: #fbf1c7;}'

services=(
  "postgresql:PostgreSQL"
  "mariadb:MariaDB"
  "mongodb:MongoDB"
  "ollama:Ollama"
)

status_icon() {
  local service="$1"
  if systemctl is-active --quiet "$service.service"; then
    printf 'ON '
  else
    printf 'OFF'
  fi
}

terminal_run() {
  local title="$1"
  local command="$2"
  env TERMINAL_TITLE="$title" TERMINAL_COMMAND="$command" alacritty --title "$title" -e bash -lc '
    export PATH="$HOME/.local/bin:/usr/local/sbin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"
    clear
    printf "\033[1;33m%s\033[0m\n\n" "$TERMINAL_TITLE"
    eval "$TERMINAL_COMMAND"
    status=$?
    printf "\n\033[2mStatus: %s\033[0m\n" "$status"
    printf "Pressione Enter para fechar..."
    read -r _
    exit "$status"
  '
}

build_menu() {
  local item service label
  for item in "${services[@]}"; do
    service="${item%%:*}"
    label="${item#*:}"
    printf '%s  %s\n' "$(status_icon "$service")" "$label"
  done
  printf 'Start all\n'
  printf 'Stop all\n'
  printf 'Status\n'
}

service_from_label() {
  local selected="$1"
  case "$selected" in
    *PostgreSQL) printf 'postgresql' ;;
    *MariaDB) printf 'mariadb' ;;
    *MongoDB) printf 'mongodb' ;;
    *Ollama) printf 'ollama' ;;
    *) return 1 ;;
  esac
}

choice="$(build_menu | rofi -dmenu -p 'Dev Services' -theme-str "$style")"

case "$choice" in
  "")
    exit 0
    ;;
  "Start all")
    terminal_run "DEV SERVICES" 'sudo systemctl start postgresql.service mariadb.service mongodb.service ollama.service; systemctl --no-pager --type=service --state=running | rg "postgresql|mariadb|mongodb|ollama" || true'
    ;;
  "Stop all")
    terminal_run "DEV SERVICES" 'sudo systemctl stop postgresql.service mariadb.service mongodb.service ollama.service; systemctl --no-pager --type=service --state=running | rg "postgresql|mariadb|mongodb|ollama" || true'
    ;;
  "Status")
    terminal_run "DEV SERVICES" 'systemctl --no-pager status postgresql.service mariadb.service mongodb.service ollama.service'
    ;;
  *)
    service="$(service_from_label "$choice")"
    if systemctl is-active --quiet "$service.service"; then
      terminal_run "DEV SERVICES" "sudo systemctl stop $service.service; systemctl --no-pager status $service.service"
    else
      terminal_run "DEV SERVICES" "sudo systemctl start $service.service; systemctl --no-pager status $service.service"
    fi
    ;;
esac
