#!/usr/bin/env bash
set -euo pipefail

config_file="${BACKUP_REAL_CONFIG:-$HOME/.config/backup/backup-real.env}"

if [[ -f "$config_file" ]]; then
  # shellcheck disable=SC1090
  source "$config_file"
fi

paths=(
  "$HOME/Documents"
  "$HOME/Projects"
  "$HOME/.ssh"
  "$HOME/.gnupg"
  "$HOME/.config"
  "$HOME/.mozilla"
  "$HOME/.pki"
  "$HOME/.local/share/keyrings"
  "$HOME/.dotfiles"
)

excludes=(
  "$HOME/.cache"
  "$HOME/.config/*/Cache"
  "$HOME/.config/*/Code Cache"
  "$HOME/.config/*/GPUCache"
  "$HOME/.config/*/Crash Reports"
  "$HOME/.config/*/*/Cache"
  "$HOME/.config/*/*/Code Cache"
  "$HOME/.config/*/*/GPUCache"
  "$HOME/.config/zen/*/cache2"
  "$HOME/.config/zen/*/startupCache"
  "$HOME/.mozilla/firefox/*/cache2"
  "$HOME/.mozilla/firefox/*/startupCache"
)

existing=()
for path in "${paths[@]}"; do
  [[ -e "$path" ]] && existing+=("$path")
done

exclude_args=()
for path in "${excludes[@]}"; do
  exclude_args+=(--exclude "$path")
done

if command -v restic >/dev/null 2>&1; then
  if [[ -z "${RESTIC_REPOSITORY:-}" ]]; then
    printf 'RESTIC_REPOSITORY is not set.\n' >&2
    printf 'Example: export RESTIC_REPOSITORY=/run/media/kenji/Backup/restic\n' >&2
    exit 2
  fi
  exec restic backup "${exclude_args[@]}" "${existing[@]}"
fi

if command -v borg >/dev/null 2>&1; then
  if [[ -z "${BORG_REPO:-}" ]]; then
    printf 'BORG_REPO is not set.\n' >&2
    printf 'Example: export BORG_REPO=/run/media/kenji/Backup/borg::thinkpad-{now}\n' >&2
    exit 2
  fi
  exec borg create --stats "${exclude_args[@]}" "$BORG_REPO" "${existing[@]}"
fi

printf 'No backup tool found. Install restic or borg.\n' >&2
exit 1
