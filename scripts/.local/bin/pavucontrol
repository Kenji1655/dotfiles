#!/usr/bin/env bash
set -euo pipefail

config_home="${XDG_RUNTIME_DIR:-/tmp}/pavucontrol-dark-config"
gtk_config="$config_home/gtk-4.0"

mkdir -p "$gtk_config"

cat > "$gtk_config/settings.ini" <<'EOF'
[Settings]
gtk-theme-name=Default
gtk-application-prefer-dark-theme=true
gtk-icon-theme-name=Papirus-Dark
gtk-cursor-theme-name=Bibata-Modern-Classic
gtk-font-name=Inter 10
EOF

cat > "$gtk_config/gtk.css" <<'EOF'
@define-color window_bg_color #1d2021;
@define-color window_fg_color #fbf1c7;
@define-color view_bg_color #282828;
@define-color view_fg_color #fbf1c7;
@define-color accent_bg_color #8ec07c;
@define-color accent_fg_color #1d2021;

* {
  background-color: #1d2021;
  color: #fbf1c7;
}

window,
dialog,
popover,
menu,
.background,
box,
viewport,
stack,
list,
listview,
treeview,
columnview,
scrolledwindow,
flowbox,
grid,
frame,
notebook,
tab,
row {
  background-color: #1d2021;
  color: #fbf1c7;
}

button,
entry,
spinbutton,
combobox,
dropdown,
scale {
  background-color: #282828;
  color: #fbf1c7;
}

label,
text,
cell {
  color: #fbf1c7;
}

row:selected,
selection {
  background-color: #8ec07c;
  color: #1d2021;
}
EOF

export XDG_CONFIG_HOME="$config_home"
export GTK_THEME="${GTK_THEME:-Default:dark}"
export ADW_DEBUG_COLOR_SCHEME="${ADW_DEBUG_COLOR_SCHEME:-prefer-dark}"

exec /usr/bin/pavucontrol "$@"
