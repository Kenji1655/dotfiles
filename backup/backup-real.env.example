# Copy to a private, git-ignored location and source it before running backup-real.
# Never commit real repository credentials or passwords.

# Restic example:
export RESTIC_REPOSITORY=/run/media/kenji/Backup/restic
# export RESTIC_PASSWORD_FILE=$HOME/.config/backup/restic-password

# Borg example:
# export BORG_REPO=/run/media/kenji/Backup/borg::thinkpad-{now}
# export BORG_PASSPHRASE_COMMAND='cat "$HOME/.config/backup/borg-passphrase"'
